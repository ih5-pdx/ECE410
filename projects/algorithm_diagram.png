from graphviz import Digraph


def create_matrix_block_diagram(output_name="matrix_block_diagram"):
    """
    Create a high-level block diagram for a matrix multiplication accelerator.

    Args:
        output_name (str): Base name of the output file (without extension).

    Returns:
        str: Path to the generated PNG file.
    """

    # Create directed graph
    dot = Digraph("Matrix_Multiplication_Block_Diagram", format="png")

    # Global graph settings
    dot.attr(rankdir="LR")
    dot.attr(
        label="High-Level Block Diagram of Target Algorithm\nMatrix Multiplication Accelerator",
        labelloc="t",
        fontsize="20"
    )

    # Main system blocks
    dot.node("CPU", "Host CPU", shape="box", style="filled", fillcolor="lightblue")
    dot.node("MEM", "Memory", shape="cylinder", style="filled", fillcolor="lightyellow")
    dot.node(
        "IF",
        "Standard Interface Bus\n(AXI-Lite or Wishbone)",
        shape="box",
        style="filled",
        fillcolor="lightgray"
    )
    dot.node(
        "ACC",
        "Matrix Multiplication Accelerator",
        shape="box",
        style="filled",
        fillcolor="lightgreen"
    )
    dot.node("OUT", "Output Matrix C", shape="box", style="filled", fillcolor="plum")

    # Internal accelerator blocks
    with dot.subgraph(name="cluster_accelerator") as c:
        c.attr(label="Inside Matrix Multiplication Accelerator", color="orange", style="rounded")
        c.node("A", "Input Matrix A", shape="box", style="filled", fillcolor="palegreen")
        c.node("B", "Input Matrix B", shape="box", style="filled", fillcolor="palegreen")
        c.node("CORE", "Matrix Multiply Core", shape="box", style="filled", fillcolor="moccasin")
        c.node("BUF", "Result Buffer /\nOutput Logic", shape="box", style="filled", fillcolor="moccasin")

        c.edge("A", "CORE")
        c.edge("B", "CORE")
        c.edge("CORE", "BUF")

    # Host-side connections
    dot.edge("CPU", "IF")
    dot.edge("MEM", "IF")
    dot.edge("IF", "ACC")
    dot.edge("BUF", "OUT")

    # Render diagram
    output_path = dot.render(output_name, cleanup=True)
    return output_path


if __name__ == "__main__":
    file_path = create_matrix_block_diagram()
    print(f"Block diagram created: {file_path}")
